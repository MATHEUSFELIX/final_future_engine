# Future Engine — Environment Configuration
# Copy this file to .env and adjust values before running.

# --- Execution Mode ---
# paper: all orders simulated locally, no real money
# live: real orders (requires LIVE_TRADING_ENABLED=true and valid credentials)
EXCHANGE_MODE=paper

# --- Exchange Provider ---
# paper: built-in paper trading engine
# live_stub: simulated live (no credentials required)
# ccxt_binance: real Binance via CCXT (requires API keys below)
EXCHANGE_PROVIDER=paper

# --- Safety Guardrail (CRÍTICO) ---
# Manter FALSE em desenvolvimento. Só setar TRUE com intenção consciente de operar em modo real.
LIVE_TRADING_ENABLED=false

# --- Binance Credentials (only required for EXCHANGE_PROVIDER=ccxt_binance) ---
CCXT_ENABLED=false
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- App Settings ---
APP_ENV=dev
API_PORT=8000
UI_PORT=8501

# --- Database ---
DB_PATH=/data/future_engine.db

# --- Risk Thresholds ---
MIN_CONFIDENCE=0.62
MAX_POSITIONS=10
DEFAULT_QTY_FRACTION=0.01
